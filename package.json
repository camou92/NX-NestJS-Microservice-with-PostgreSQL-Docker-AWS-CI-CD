{
  "name": "@jobber/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "nx run-many -t serve -p auth jobs executor",
    "generate-ts-proto": "protoc --plugin=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=libs/proto/src/lib --ts_proto_opt=nestJs=true -I ./libs/proto/proto ./libs/proto/proto/*.proto"
  },
  "nx": {
    "targets": {
      "generate-ts-proto": {
        "inputs": [
          "{workspaceRoot}/proto/*.proto"
        ],
        "cache": false
      }
    }
  },
  "private": true,
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "@golevelup/nestjs-discovery": "^6.1.1",
