{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "types": ["node"],
    "rootDir": "src",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es2021"
  },
  "include": ["src/**/*.ts", "src/app/decorators/job.decorator.ts"],
  "exclude": [
    "out-tsc",
    "dist",
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs"
  ],
  "references": [
    {
      "path": "../../libs/proto/tsconfig.lib.json"
    },
    {
      "path": "../../libs/graphql/tsconfig.lib.json"
    },
    {
      "path": "../../libs/nestjs/tsconfig.lib.json"
    },
    {
      "path": "../../libs/pulsar/tsconfig.lib.json"
    }
  ]
}
